      "temperature_celsius": "-25 or below",
      "max_storage_months": 24,
      "notes": "Must be thawed to 37°C before transfusion; use within 4 hours of thawing."
    },
    "platelets": {
      "temperature_celsius": "20–24",
      "max_storage_days": 7,
      "agitation_required": true,
      "notes": "Stored with continuous gentle agitation to prevent clumping."
    },
